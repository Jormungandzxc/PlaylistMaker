<?xml version="1.0" encoding="utf-8"?>
<resources>
<!--    General-->

    <style name="ToolbarTitleTextStyle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">@color/title_text_color</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/ts_main_22</item>
    </style>

    <style name="Small_text_style">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="TrackNameTextStyle">
        <item name="android:textColor">@color/track_name_color</item>
        <item name="android:textSize">@dimen/ts_regular</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="ArtistNameTextStyle">
        <item name="android:textColor">@color/track_artist_name_color</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>


<!--    Main activity-->

    <style name="MainButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="cornerRadius">@dimen/btn_main_radius</item>
    </style>
    
    <style name="MainButtonTextStyle" parent="MainButtonStyle">
        <item name="android:letterSpacing">0</item>
        <item name="textAllCaps">false</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">@dimen/ts_main_22</item>
        <item name="fontFamily">@font/ys_display_medium</item>
    </style>
    
    <style name="MainButtonWithIconStyle" parent="MainButtonTextStyle">
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">@color/text_color</item>
    </style>


    <!--    Settings activity-->

    <style name="btn_user_agreement" parent="SettingsButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">61dp</item>
        <item name="android:clickable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">@dimen/settings_btn_padStart</item>
        <item name="android:paddingEnd">@dimen/settings_btn_padEnd</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="SettingsSwitchButtonStyle" parent="btn_user_agreement">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">@dimen/ts_regular</item>
    </style>


    <style name="SettingsButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">@dimen/ts_regular</item>
    </style>

<!--    Search activity-->

    <style name="Edittext_search_bg_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginHorizontal">16dp</item>
        <item name="android:layout_marginVertical">8dp</item>
        <item name="android:background">@drawable/edittext_search_round_bg_shape</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">40dp</item>
        <item name="android:textColorHint">@color/hint_color</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_color</item>
    </style>

    <style name="PlaceholderRefreshButtonStyle">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:backgroundTint">@color/track_name_color</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/ts_main_14</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/refresh_btn_text_color</item>
    </style>


    <!--    Player activity-->

    <style name="PlayerTrackNameTS">
        <item name="android:textColor">@color/title_text_color</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/ts_main_22</item>
    </style>



</resources>