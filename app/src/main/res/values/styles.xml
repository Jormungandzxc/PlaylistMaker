<?xml version="1.0" encoding="utf-8"?>
<resources>
<!--    Main activity-->

    <style name="MainButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="cornerRadius">@dimen/btn_main_radius</item>
    </style>
    
    <style name="MainButtonTextStyle" parent="MainButtonStyle">
        <item name="android:letterSpacing">0</item>
        <item name="textAllCaps">false</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">@dimen/ts_main</item>
        <item name="fontFamily">@font/ys_display_regular</item>
    </style>
    
    <style name="MainButtonWithIconStyle" parent="MainButtonTextStyle">
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
        <item name="iconTint">@color/text_color</item>
    </style>


    <!--    Settings activity-->

    <style name="SettingsButtonStyle" parent="SettingsButtonTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">61dp</item>
        <item name="android:clickable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">@dimen/settings_btn_padStart</item>
        <item name="android:paddingEnd">@dimen/settings_btn_padEnd</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="SettingsSwitchButtonStyle" parent="SettingsButtonStyle">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">@dimen/ts_regular</item>
    </style>


    <style name="SettingsButtonTextStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">@dimen/ts_regular</item>
    </style>

</resources>